# ============================================================================
# server.cfg.example — hardened reference server.cfg
#
# REFERENCE only. The live server.cfg is generated by the txAdmin qbox-lean
# recipe; this example documents the values we want tuned and the load
# order. Diff your live server.cfg against this file after a recipe deploy
# and reconcile any drift.
#
# Secrets MUST live in txAdmin's secret store, never in this repo.
# ============================================================================

# ---------------------------------------------------------------------------
# Network endpoints
# ---------------------------------------------------------------------------
endpoint_add_tcp "0.0.0.0:30120"
endpoint_add_udp "0.0.0.0:30120"
sv_endpointprivacy true

# ---------------------------------------------------------------------------
# Slots & game build
# ---------------------------------------------------------------------------
sv_maxclients 48

# Pin the game build. Set to the current Cfx-recommended build for Qbox.
sv_enforceGameBuild 3258

set onesync on

# ---------------------------------------------------------------------------
# Server identity
# ---------------------------------------------------------------------------
sv_hostname "gtarp — Qbox RP"
sv_projectName "gtarp"
sv_projectDesc "Qbox-based roleplay server"
locale "en-US"
load_server_icon icon.png
sets tags "roleplay, qbox, whitelist"
sets locale "en-US"

# ---------------------------------------------------------------------------
# Secrets — managed by txAdmin
# ---------------------------------------------------------------------------
# sv_licenseKey   "CHANGEME_TXADMIN_MANAGED"
# set steam_webApiKey "CHANGEME_TXADMIN_MANAGED"

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
set mysql_connection_string "mysql://user:CHANGEME@127.0.0.1:3306/qbox?charset=utf8mb4"

# ---------------------------------------------------------------------------
# Resource load order
# ---------------------------------------------------------------------------
ensure ox_lib
ensure oxmysql
ensure ox_target
ensure ox_inventory

ensure qbx_core

# Framework resources (qbx_management, qbx_vehicles, qbx_garages, qbx_police,
# qbx_ambulancejob, etc.) — recipe-provided, ensured by the recipe block
# above this line.

# Custom layer — must be last. custom.cfg ensures:
#   qbx_core_overrides -> server_identity -> server_base
# and grants `command.coords` to group.admin.
exec custom.cfg

# ---------------------------------------------------------------------------
# ACE permissions (admin example)
# ---------------------------------------------------------------------------
add_ace group.admin command       allow
add_ace group.admin command.quit  deny
add_principal identifier.license:CHANGEME group.admin
